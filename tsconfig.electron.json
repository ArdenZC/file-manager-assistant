{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-electron",
    "rootDir": ".",
    "types": ["node", "electron"],
    "sourceMap": true
  },
  "include": ["electron/**/*.ts", "electron/**/*.cts", "src/core/**/*.ts", "src/types/**/*.ts"]
}
